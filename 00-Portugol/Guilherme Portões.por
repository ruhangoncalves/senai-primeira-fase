programa {
  funcao inicio() {
   //criar variáveis
   inteiro clt, estagiarios, pj, total
   //ler valores de entrada
   escreva("Quantidade de CLT's: ")
   leia(clt)
   //processar / calcular
   escreva("Quantidade de estagiários: ")
   leia(estagiarios)
   escreva("Quantidade de PJ's: ")
   leia(pj)
   total= clt + estagiarios + pj
    //leitura dos dados
   escreva("\nQuantidade total de funcionários: " + total)

  }
}
